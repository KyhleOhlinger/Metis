{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities granted to all Metis windows (primary + secondary vault windows)",
  "windows": ["main", "vault_*"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://**" },
        { "url": "http://127.0.0.1:**" },
        { "url": "http://localhost:**" },
        { "url": "https://date.nager.at/**" }
      ]
    },
    "http:allow-fetch-cancel",
    "http:allow-fetch-read-body",
    "http:allow-fetch-send"
  ]
}
