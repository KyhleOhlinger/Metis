{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Metis",
  "version": "0.1.0",
  "identifier": "com.metis.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "windows": [
      {
        "title": "Metis",
        "width": 1400,
        "height": 900,
        "minWidth": 580,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": "default-src 'self' asset: blob:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob: https:; font-src 'self' data:; connect-src 'self' https://api.openai.com https://generativelanguage.googleapis.com https://api.groq.com https://api.perplexity.ai https://llm-gateway.prod.plat.unauth.wayfair.io https://date.nager.at"
    }
  },
  "bundle": {
    "resources": [
      "resources/dictionaries/**/*"
    ],
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
